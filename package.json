{
  "name": "cooking-video",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + React + Vite + Tailwind desktop app",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "setup:mediapipe": "node scripts/setup-mediapipe.mjs",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "vercel-build": "node scripts/setup-mediapipe.mjs && vite build",
    "build": "npm run build:renderer && electron-builder",
    "dist:desktop": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/hands": "^0.4.1675469240",
    "@mediapipe/tasks-vision": "^0.10.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-youtube": "^10.1.0"
  },
  "build": {
    "appId": "com.cookingvideo.app",
    "productName": "Cooking Video",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "extendInfo": {
        "NSCameraUsageDescription": "This app needs access to your camera to record cooking videos.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record audio."
      }
    }
  }
}
